---
/**
 * Dark hero band (design: Home Page Directions 3a).
 * Heading comes through the slot so copy can include <em> for the
 * italic Fraunces moment. If `image` is provided it fills the circular
 * frame; otherwise the DG monogram shows.
 *
 * variant="nightfall" (design: Portfolio Home 1b) paints the band with
 * the horizon gradient — pink glow rising into magenta at the bottom
 * edge — plus a slow-pulsing "sun" low on the horizon (CSS-only;
 * freezes under prefers-reduced-motion via the global rule).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  sub?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  /** Source image from src/assets — cropped square for the circular frame */
  image?: ImageMetadata;
  imageAlt?: string;
  monogram?: string;
  variant?: 'default' | 'nightfall';
}

const {
  eyebrow,
  sub,
  primaryLabel,
  primaryHref = '/work',
  secondaryLabel,
  secondaryHref = '/about',
  image,
  imageAlt = '',
  monogram = 'DG',
  variant = 'default',
} = Astro.props;
---

<section class:list={['hero', { 'hero--nightfall': variant === 'nightfall' }]}>
  <div class="container hero__inner">
    <div class="hero__copy">
      {
        eyebrow && (
          <p class="hero__eyebrow">
            <span class="hero__dot" aria-hidden="true" />
            {eyebrow}
          </p>
        )
      }
      <h1 class="hero__heading"><slot /></h1>
      {sub && <p class="hero__sub">{sub}</p>}
      <div class="hero__actions">
        {
          primaryLabel && (
            <a class="button" href={primaryHref}>
              {primaryLabel} <span aria-hidden="true">→</span>
            </a>
          )
        }
        {
          secondaryLabel && (
            <a class="button button--secondary" href={secondaryHref}>
              {secondaryLabel}
            </a>
          )
        }
      </div>
    </div>

    <div class="hero__media">
      <div class="hero__circle">
        {
          image ? (
            <Image
              src={image}
              alt={imageAlt}
              width={280}
              height={280}
              densities={[1, 2]}
              loading="eager"
            />
          ) : (
            <span class="hero__monogram" aria-hidden="true">{monogram}</span>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg);
    color: var(--color-text);
    padding-block: var(--space-8) var(--space-9);
  }

  /* ---- Nightfall (1b): the horizon gradient lives here ---- */
  .hero--nightfall {
    position: relative;
    overflow: hidden;
    background: var(--band-hero, var(--color-bg));
  }

  /* The soft pulsing "sun" low on the horizon */
  .hero--nightfall::before {
    content: '';
    position: absolute;
    inset-block-end: -14%;
    inset-inline-start: 32%;
    width: 36%;
    height: 52%;
    border-radius: 50%;
    background: var(--band-hero-sun, none);
    animation: sun-pulse 9s ease-in-out infinite;
    pointer-events: none;
  }

  .hero--nightfall .hero__inner {
    position: relative;
    z-index: 1;
  }

  .hero--nightfall .hero__dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 4px
      color-mix(in srgb, var(--color-accent) 28%, transparent);
  }

  @keyframes sun-pulse {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 0.9fr);
    gap: var(--space-8);
    align-items: center;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-block-end: var(--space-5);
    font-size: 0.8125rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-text-muted);
  }

  .hero__heading {
    font-size: var(--text-3xl);
    line-height: var(--leading-hero);
    max-width: 16ch;
  }

  .hero__heading :global(em) {
    font-style: italic;
  }

  .hero__sub {
    margin-block-start: var(--space-6);
    font-size: var(--text-md);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 52ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-block-start: var(--space-7);
  }

  .hero__media {
    justify-self: center;
  }

  .hero__circle {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: var(--color-bg-raised);
    border: var(--border-thin) solid var(--color-border-control);
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .hero__circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__monogram {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__media {
      order: -1;
      justify-self: start;
    }

    .hero__circle {
      width: 180px;
      height: 180px;
    }

    .hero__monogram {
      font-size: 4rem;
    }
  }
</style>
