---
/**
 * Dark hero band (design: Home Page Directions 3a).
 * Heading comes through the slot so copy can include <em> for the
 * italic Fraunces moment. If `image` is provided it fills the circular
 * frame; otherwise the DG monogram shows.
 *
 * variant="nightfall" (design: Portfolio Home 1b) paints the band with
 * the horizon gradient — pink glow rising into magenta at the bottom
 * edge — plus a slow-pulsing "sun" low on the horizon (CSS-only;
 * freezes under prefers-reduced-motion via the global rule).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  sub?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  /** Source image from src/assets — cropped square for the circular frame */
  image?: ImageMetadata;
  imageAlt?: string;
  monogram?: string;
  variant?: 'default' | 'nightfall';
}

const {
  eyebrow,
  sub,
  primaryLabel,
  primaryHref = '/work',
  secondaryLabel,
  secondaryHref = '/about',
  image,
  imageAlt = '',
  monogram = 'DG',
  variant = 'default',
} = Astro.props;
---

<section class:list={['hero', { 'hero--nightfall': variant === 'nightfall' }]}>
  {
    variant === 'nightfall' && (
      <div class="hero__boat" aria-hidden="true">
        <div class="hero__boat-hull">
          <svg width="48" height="36" viewBox="0 0 48 36">
            <g fill="#1a0a24">
              <path d="M22 1 L22 21 L5 21 Z" />
              <path d="M24 5 L38 21 L24 21 Z" />
              <path d="M2 23 L46 23 L40 32 L8 32 Z" />
            </g>
          </svg>
        </div>
        <div class="hero__boat-wake">
          <span class="hero__boat-wake--aft-far" />
          <span class="hero__boat-wake--aft" />
          <span class="hero__boat-wake--bow" />
        </div>
      </div>
    )
  }
  <div class="container hero__inner">
    <div class="hero__copy">
      {
        eyebrow && (
          <p class="hero__eyebrow">
            <span class="hero__dot" aria-hidden="true" />
            {eyebrow}
          </p>
        )
      }
      <h1 class="hero__heading"><slot /></h1>
      {sub && <p class="hero__sub">{sub}</p>}
      <div class="hero__actions">
        {
          primaryLabel && (
            <a class="button" href={primaryHref}>
              {primaryLabel} <span aria-hidden="true">→</span>
            </a>
          )
        }
        {
          secondaryLabel && (
            <a class="button button--secondary" href={secondaryHref}>
              {secondaryLabel}
            </a>
          )
        }
      </div>
    </div>

    <div class="hero__media">
      <div class="hero__circle">
        {
          image ? (
            <Image
              src={image}
              alt={imageAlt}
              width={210}
              height={210}
              densities={[1, 2]}
              loading="eager"
            />
          ) : (
            <span class="hero__monogram" aria-hidden="true">{monogram}</span>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg);
    color: var(--color-text);
    padding-block: var(--space-8) var(--space-9);
  }

  /* ---- Nightfall (1b): the horizon gradient lives here ---- */
  .hero--nightfall {
    position: relative;
    overflow: hidden;
    background: var(--band-hero, var(--color-bg));
  }

  /* The soft pulsing "sun" low on the horizon */
  .hero--nightfall::before {
    content: '';
    position: absolute;
    inset-block-end: -14%;
    inset-inline-start: 32%;
    width: 36%;
    height: 52%;
    border-radius: 50%;
    background: var(--band-hero-sun, none);
    animation: sun-pulse 9s ease-in-out infinite;
    pointer-events: none;
  }

  .hero--nightfall .hero__inner {
    position: relative;
    z-index: 1;
  }

  /* A darkened band along the bottom edge — the "sea" the boat sits
     on. Without it the silhouette reads as floating in the sky glow. */
  .hero--nightfall::after {
    content: '';
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    height: 3.5rem;
    background: linear-gradient(
      180deg,
      rgb(26 10 36 / 0) 0%,
      rgb(26 10 36 / 0.45) 100%
    );
    pointer-events: none;
  }

  .hero--nightfall .hero__dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 4px
      color-mix(in srgb, var(--color-accent) 28%, transparent);
  }

  @keyframes sun-pulse {
    0%,
    100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
    }
  }

  /* ---- The sailboat (1b) — a silhouette drifting across the
     horizon, bobbing, with a soft wake. Pure CSS; raw colors here
     are Nightfall art-direction values (like the gradient stops),
     not UI tokens. Under prefers-reduced-motion the global rule
     freezes animation at 0% — the boat simply stays invisible. */
  /* Hull sits slightly below the section edge so its bottom is
     clipped — the boat reads as riding IN the black sea (the dark
     section below), not floating above it. */
  .hero__boat {
    position: absolute;
    inset-block-end: -7px;
    inset-inline-start: 44%;
    z-index: 1;
    pointer-events: none;
    transform-origin: bottom center;
    animation: boat-approach 52s linear infinite;
  }

  .hero__boat-hull {
    animation: boat-bob 4s ease-in-out infinite;
  }

  .hero__boat-hull svg {
    display: block;
    filter: drop-shadow(0 2px 4px rgb(0 0 0 / 0.45));
  }

  /* Ripples ahead of the bow and trailing the stern, at the
     waterline. Each has its own non-harmonic duration, delay,
     size, and drift direction, so the combined pattern only
     repeats every few minutes — it reads as random water rather
     than a metronome. */
  .hero__boat-wake {
    position: absolute;
    inset-block-end: 9px;
    inset-inline: 0;
  }

  .hero__boat-wake span {
    position: absolute;
    height: 5px;
    border-radius: 50%;
  }

  .hero__boat-wake--bow {
    inset-inline-end: -30px;
    width: 24px;
    background: rgb(255 200 224 / 0.45);
    animation: wake-bow 2.7s ease-out infinite;
  }

  .hero__boat-wake--aft {
    inset-inline-start: -24px;
    width: 26px;
    background: rgb(255 200 224 / 0.35);
    animation: wake-aft 3.9s ease-out infinite 0.8s;
  }

  .hero__boat-wake--aft-far {
    inset-inline-start: -46px;
    width: 20px;
    background: rgb(255 200 224 / 0.25);
    animation: wake-aft-far 4.6s ease-out infinite 2.1s;
  }

  @keyframes boat-approach {
    0% {
      transform: translateX(-560px);
      opacity: 0;
    }
    8% {
      opacity: 1;
    }
    92% {
      opacity: 1;
    }
    100% {
      transform: translateX(560px);
      opacity: 0;
    }
  }

  @keyframes boat-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-2px);
    }
  }

  @keyframes wake-bow {
    0% {
      transform: translateX(0) scaleX(0.35) scaleY(0.6);
      opacity: 0;
    }
    22% {
      opacity: 0.55;
    }
    58% {
      opacity: 0.25;
    }
    100% {
      transform: translateX(10px) scaleX(1.7) scaleY(1);
      opacity: 0;
    }
  }

  @keyframes wake-aft {
    0% {
      transform: translateX(0) scaleX(0.4) scaleY(0.6);
      opacity: 0;
    }
    30% {
      opacity: 0.45;
    }
    100% {
      transform: translateX(-14px) scaleX(2) scaleY(1);
      opacity: 0;
    }
  }

  @keyframes wake-aft-far {
    0% {
      transform: translateX(0) scaleX(0.5) scaleY(0.7);
      opacity: 0;
    }
    18% {
      opacity: 0.3;
    }
    71% {
      opacity: 0.18;
    }
    100% {
      transform: translateX(-9px) scaleX(1.6) scaleY(1);
      opacity: 0;
    }
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 0.9fr);
    gap: var(--space-8);
    align-items: center;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-block-end: var(--space-5);
    font-size: 0.8125rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-text-muted);
  }

  .hero__heading {
    font-size: var(--text-3xl);
    line-height: var(--leading-hero);
    max-width: 16ch;
  }

  .hero__heading :global(em) {
    font-style: italic;
  }

  .hero__sub {
    margin-block-start: var(--space-6);
    font-size: var(--text-md);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 52ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-block-start: var(--space-7);
  }

  .hero__media {
    justify-self: center;
  }

  .hero__circle {
    width: 210px;
    height: 210px;
    border-radius: 50%;
    background: var(--color-bg-raised);
    border: var(--border-thin) solid var(--color-border-control);
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .hero__circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__monogram {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__media {
      order: -1;
      justify-self: start;
    }

    .hero__circle {
      width: 135px;
      height: 135px;
    }

    .hero__monogram {
      font-size: 4rem;
    }
  }
</style>
