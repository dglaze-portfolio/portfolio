---
/**
 * Dark hero band (design: Home Page Directions 3a).
 * Heading comes through the slot so copy can include <em> for the
 * italic Fraunces moment. If `image` is provided it fills the circular
 * frame; otherwise the DG monogram shows.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  sub?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  /** Source image from src/assets — cropped square for the circular frame */
  image?: ImageMetadata;
  imageAlt?: string;
  monogram?: string;
}

const {
  eyebrow,
  sub,
  primaryLabel,
  primaryHref = '/work',
  secondaryLabel,
  secondaryHref = '/about',
  image,
  imageAlt = '',
  monogram = 'DG',
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      {
        eyebrow && (
          <p class="hero__eyebrow">
            <span class="hero__dot" aria-hidden="true" />
            {eyebrow}
          </p>
        )
      }
      <h1 class="hero__heading"><slot /></h1>
      {sub && <p class="hero__sub">{sub}</p>}
      <div class="hero__actions">
        {
          primaryLabel && (
            <a class="button" href={primaryHref}>
              {primaryLabel} <span aria-hidden="true">→</span>
            </a>
          )
        }
        {
          secondaryLabel && (
            <a class="button button--secondary" href={secondaryHref}>
              {secondaryLabel}
            </a>
          )
        }
      </div>
    </div>

    <div class="hero__media">
      <div class="hero__circle">
        {
          image ? (
            <Image
              src={image}
              alt={imageAlt}
              width={280}
              height={280}
              densities={[1, 2]}
              loading="eager"
            />
          ) : (
            <span class="hero__monogram" aria-hidden="true">{monogram}</span>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--color-bg);
    color: var(--color-text);
    padding-block: var(--space-8) var(--space-9);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(0, 0.9fr);
    gap: var(--space-8);
    align-items: center;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-block-end: var(--space-5);
    font-size: 0.8125rem;
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .hero__dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--color-text-muted);
  }

  .hero__heading {
    font-size: var(--text-3xl);
    line-height: var(--leading-hero);
    max-width: 16ch;
  }

  .hero__heading :global(em) {
    font-style: italic;
  }

  .hero__sub {
    margin-block-start: var(--space-6);
    font-size: var(--text-md);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 52ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-block-start: var(--space-7);
  }

  .hero__media {
    justify-self: center;
  }

  .hero__circle {
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: var(--color-bg-raised);
    border: var(--border-thin) solid var(--color-border-control);
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .hero__circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__monogram {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }

    .hero__media {
      order: -1;
      justify-self: start;
    }

    .hero__circle {
      width: 180px;
      height: 180px;
    }

    .hero__monogram {
      font-size: 4rem;
    }
  }
</style>
