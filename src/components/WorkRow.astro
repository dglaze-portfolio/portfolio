---
/**
 * Horizontal case study row for the home showcase
 * (design: Home Page Directions 3a).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href: string;
  index: number;
  client: string;
  category?: string;
  title: string;
  tagline: string;
  chips?: string[];
  highlightChip?: string;
  featured?: boolean;
  /** Source image from src/assets — cropped to 8:5 at build time */
  cover?: ImageMetadata;
  coverAlt?: string;
}

const {
  href,
  index,
  client,
  category,
  title,
  tagline,
  chips = [],
  highlightChip,
  featured = false,
  cover,
  coverAlt = '',
} = Astro.props;

const number = String(index).padStart(2, '0');
const initial = client.charAt(0);
const eyebrowText = category ? `${client} · ${category}` : client;
---

<a class="row" href={href}>
  <div class="row__media">
    {
      cover ? (
        <Image
          src={cover}
          alt={coverAlt}
          width={340}
          height={212}
          densities={[1, 2]}
          loading="lazy"
        />
      ) : (
        <div class="row__placeholder" aria-hidden="true">
          <span class="row__initial">{initial}</span>
          <span class="row__preview-label">Preview</span>
        </div>
      )
    }
  </div>

  <div class="row__body">
    <p class="row__eyebrow">{eyebrowText}</p>
    <h3 class="row__title">{title}</h3>
    <p class="row__tagline">{tagline}</p>
    {
      (chips.length > 0 || highlightChip) && (
        <div class="row__chips">
          {chips.map((chip) => (
            <span class="chip">{chip}</span>
          ))}
          {highlightChip && <span class="chip chip--accent">{highlightChip}</span>}
        </div>
      )
    }
  </div>

  <span class="row__number" aria-hidden="true">{number}</span>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: minmax(0, 340px) minmax(0, 1fr) auto;
    gap: var(--space-6);
    align-items: center;
    background: var(--card-bg);
    border: var(--border-thin) solid var(--card-border);
    border-radius: var(--card-radius);
    padding: var(--space-5);
    box-shadow: var(--card-shadow);
    color: inherit;
    text-decoration: none;
    transition:
      box-shadow var(--duration-base) var(--ease-out),
      translate var(--duration-base) var(--ease-out);
  }

  .row:hover {
    box-shadow: var(--card-shadow-hover);
    translate: 0 -2px;
    color: inherit;
  }

  .row__media img,
  .row__placeholder {
    aspect-ratio: 8 / 5;
    width: 100%;
    border-radius: var(--radius-md);
    object-fit: cover;
  }

  .row__placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    background: var(--color-bg-subtle);
    border: var(--border-thin) solid var(--color-border);
  }

  .row__initial {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
  }

  .row__preview-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .row__eyebrow {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .row__title {
    margin-block-start: var(--space-2);
    font-size: var(--text-lg);
    line-height: var(--leading-tight);
  }

  .row__tagline {
    margin-block-start: var(--space-3);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-text-secondary);
    max-width: 60ch;
  }

  .row__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-block-start: var(--space-4);
  }

  .chip {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--chip-text);
    background: var(--chip-bg);
    border-radius: var(--radius-full);
    padding: 5px 12px;
  }

  .chip--accent {
    font-weight: var(--weight-semibold);
    color: var(--chip-accent-text);
    background: var(--chip-accent-bg);
  }

  .row__number {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: var(--weight-medium);
    color: var(--color-ornament);
    align-self: center;
    padding-inline-end: var(--space-2);
  }

  @media (max-width: 900px) {
    .row {
      grid-template-columns: 1fr;
    }

    .row__number {
      display: none;
    }
  }
</style>
