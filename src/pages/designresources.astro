---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';

/**
 * Design resources.
 * TODO: The live Squarespace page was rate-limiting during migration —
 * add your real resources to this list (it renders automatically).
 */
const resources: { title: string; description: string; href: string }[] = [
  // {
  //   title: 'Resource name',
  //   description: 'One-line description of what it is and who it helps.',
  //   href: 'https://example.com',
  // },
];
---

<BaseLayout
  title="Design Resources"
  description="Tools, templates, and references for designers and design teams."
>
  <section class="section--tight">
    <div class="container container--narrow">
      <h1>Design Resources</h1>
      <p class="intro">
        Tools, templates, and references I share with designers and design
        teams.
      </p>

      {
        resources.length > 0 ? (
          <ul class="resource-list">
            {resources.map((r) => (
              <li class="resource">
                <h2 class="resource__title">
                  <a href={r.href}>{r.title}</a>
                </h2>
                <p class="resource__desc">{r.description}</p>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">New resources are on the way — check back soon.</p>
        )
      }
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  .intro {
    margin-block-start: var(--space-4);
    font-size: var(--text-md);
    color: var(--color-text-secondary);
  }

  .resource-list {
    list-style: none;
    margin: var(--space-7) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }

  .resource {
    background: var(--card-bg);
    border: var(--border-thin) solid var(--card-border);
    border-radius: var(--card-radius);
    padding: var(--space-5);
  }

  .resource__title {
    font-size: var(--text-lg);
  }

  .resource__desc {
    margin-block-start: var(--space-2);
    color: var(--color-text-secondary);
  }

  .empty {
    margin-block-start: var(--space-7);
    color: var(--color-text-muted);
  }
</style>
