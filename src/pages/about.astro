---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout
  title="About"
  description="Deanna Glaze — product designer and player-coach working across AI, publishing, and digital health."
  theme="aurora"
>
  <section class="section--tight">
    <div class="container about">
      <div class="about__portrait">
        <img
          src="/images/about/workshop.jpg"
          alt="Deanna leading an audience-mapping workshop, smiling in front of a wall of grouped sticky notes"
          width="480"
          height="600"
          loading="eager"
        />
      </div>
      <div class="about__copy prose">
        <h1>About me</h1>
        <p>
          Hi. I'm Deanna. I'm a product leader who believes the best digital experiences are built on clear storytelling, human trust, and solid systems.
        </p>
        <p>
          My background spans AI, publishing, and digital health at places like Amazon, Audible, and Virgin Pulse, along with scrappy startups. With a foundation in graphic design and creative writing, I'm as comfortable shaping product strategy and design ops as I am writing UX copy or mapping complex user flows. Lately, I've been thinking deeply about how we design for AI, moving beyond tool hype to build non-linear, ethical experiences that earn long-term user trust.
        </p>
        <p>
          Outside of my design work, you'll find me working on Aerial Books, my online bookstore exploring new ways readers discover stories.
        </p>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    gap: var(--space-8);
    align-items: start;
  }

  .about__portrait img {
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  @media (max-width: 720px) {
    .about {
      grid-template-columns: 1fr;
    }

    .about__portrait img {
      max-width: 320px;
    }
  }
</style>
