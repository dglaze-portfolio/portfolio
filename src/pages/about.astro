---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
---

<BaseLayout
  title="About"
  description="Deanna Glaze — product designer and player-coach working across AI, publishing, and digital health."
  theme="aurora"
>
  <section class="section--tight">
    <div class="container about">
      <div class="about__portrait">
        <img
          src="/images/about/workshop.jpg"
          alt="Deanna leading an audience-mapping workshop, smiling in front of a wall of grouped sticky notes"
          width="480"
          height="600"
          loading="eager"
        />
      </div>
      <div class="about__copy prose">
        <h1>About me</h1>
        <p>
          Hi. I'm Deanna, a product designer and a player-coach. I like complex
          problems, continuous research, and writing the content that makes a
          flow make sense. I've worked across AI, publishing, and digital
          health at places like Amazon, Audible, and Virgin Pulse, as well as
          scrappy startups.
        </p>
        <p>
          I build systems that help teams move faster. I care about inclusive,
          accessible experiences and practical craft.
        </p>
        <p>
          Outside of my design work, I'm passionate about storytelling and
          creative expression. My personal project, Aerial Books, is an
          evolving digital bookstore exploring new ways to connect stories with
          readers.
        </p>
        <p>
          I'm driven by curiosity, collaboration, and the belief that great
          design can improve lives in both big and small ways. Let's create
          meaningful experiences together.
        </p>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    gap: var(--space-8);
    align-items: start;
  }

  .about__portrait img {
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  @media (max-width: 720px) {
    .about {
      grid-template-columns: 1fr;
    }

    .about__portrait img {
      max-width: 320px;
    }
  }
</style>
