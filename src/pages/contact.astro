---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL } from '../data/site';

const linkedin = SOCIAL.find((s) => s.label === 'LinkedIn')?.href;
---

<BaseLayout
  title="Contact"
  description="Get in touch with Deanna Glaze about product design, AI-UX, and collaboration."
  theme="aurora"
>
  <section class="section--tight">
    <div class="container contact">
      <div class="contact__intro">
        <p class="eyebrow">Let's connect</p>
        <h1 class="contact__heading">Tell me what you're working on.</h1>
        <p class="contact__body">
          Interested in collaborating, or want to talk through a hard design
          problem? Send a note and it lands straight in my inbox.
        </p>
        {
          linkedin && (
            <p class="contact__alt">
              Prefer to connect on{' '}
              <a href={linkedin} rel="me noopener" target="_blank">
                LinkedIn
              </a>
              ? That works too.
            </p>
          )
        }
      </div>

      <form class="contact-form" method="POST" action="/api/contact">
        <p class="field">
          <label for="cf-name">Name</label>
          <input id="cf-name" name="name" type="text" required maxlength="200" autocomplete="name" />
        </p>
        <p class="field">
          <label for="cf-email">Email</label>
          <input id="cf-email" name="email" type="email" required maxlength="200" autocomplete="email" />
        </p>
        <p class="field">
          <label for="cf-message">Message</label>
          <textarea id="cf-message" name="message" required maxlength="5000" rows="7"></textarea>
        </p>
        <!-- Honeypot: hidden from people, irresistible to bots -->
        <p class="field field--hp" aria-hidden="true">
          <label for="cf-company">Company</label>
          <input id="cf-company" name="company" type="text" tabindex="-1" autocomplete="off" />
        </p>
        <p class="contact-form__actions">
          <button class="button" type="submit">
            Send message <span aria-hidden="true">→</span>
          </button>
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
    gap: var(--space-8);
    align-items: start;
  }

  .contact__heading {
    margin-block-start: var(--space-4);
    font-size: var(--text-2xl);
  }

  .contact__body {
    margin-block-start: var(--space-5);
    color: var(--color-text-secondary);
    font-size: var(--text-md);
    line-height: var(--leading-normal);
    max-width: 40ch;
  }

  .contact__alt {
    margin-block-start: var(--space-4);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .contact-form {
    display: grid;
    gap: var(--space-5);
    background: var(--color-bg-raised);
    border: var(--border-thin) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
  }

  .field {
    display: grid;
    gap: var(--space-2);
  }

  .field label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
  }

  .field input,
  .field textarea {
    width: 100%;
    background: var(--color-bg-subtle);
    border: var(--border-thin) solid var(--color-border-control);
    border-radius: var(--radius-sm);
    padding: var(--space-3);
    color: var(--color-text);
    font: inherit;
  }

  .field textarea {
    resize: vertical;
    min-height: 9rem;
  }

  /* Honeypot — parked far off-canvas, skipped by keyboard order. */
  .field--hp {
    position: absolute;
    inset-inline-start: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-form__actions {
    margin: 0;
  }

  .contact-form .button {
    cursor: pointer;
  }

  @media (max-width: 820px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }
</style>
