---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WorkRow from '../components/WorkRow.astro';
import deannaIllus from '../assets/home/deanna-illus.png';

const projects = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const approach = [
  {
    n: '01',
    title: 'Clarity & shared ownership',
    body: 'Inclusive by default. Bring in quieter voices early; ownership stays clear.',
  },
  {
    n: '02',
    title: 'Evidence-led strategy',
    body: 'Research frames the problem and shapes measurable goals.',
  },
  {
    n: '03',
    title: 'Systems-level impact',
    body: 'Patterns, naming, and guidance that scale across teams.',
  },
  {
    n: '04',
    title: 'Glass Box',
    body: 'When software acts on your behalf, you should see it and stay in control.',
  },
];
---

<BaseLayout theme="nightfall">
  <Hero
    eyebrow="Product Design Leader · AI-UX"
    sub="Product designer working on agentic AI. I design the interaction model for systems that act on people's behalf, and build the tooling that gets it shipped."
    primaryLabel="Explore the work"
    primaryHref="/work"
    secondaryLabel="About me"
    secondaryHref="/about"
    image={deannaIllus}
    imageAlt="Illustration of Deanna Glaze"
    variant="nightfall"
  >
    I make complex systems clear, and <em>keep people in control of them</em>.
  </Hero>

  <section class="approach" aria-labelledby="approach-heading">
    <div class="container">
      <p class="eyebrow">How I work</p>
      <h2 id="approach-heading" class="approach__heading">
        Clarity first. Then agency.
      </h2>
      <ul class="approach__grid">
        {
          approach.map((step) => (
            <li class="step">
              <span class="step__number" aria-hidden="true">{step.n}</span>
              <p class="step__title">{step.title}</p>
              <p class="step__body">{step.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="showcase" aria-labelledby="work-heading">
    <div class="container">
      <div class="showcase__head">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="work-heading" class="showcase__heading">
            Case studies across AI, health, and enterprise platforms
          </h2>
        </div>
        <a class="showcase__all" href="/work">All work →</a>
      </div>
      <div class="showcase__list">
        {
          projects.map((project, i) => (
            <WorkRow
              href={`/work/${project.id}`}
              index={i + 1}
              client={project.data.client}
              category={project.data.category}
              title={project.data.shortTitle ?? project.data.title}
              tagline={project.data.tagline}
              chips={project.data.chips}
              highlightChip={project.data.highlightChip}
              featured={project.data.featured}
              cover={project.data.cover}
              coverAlt={project.data.coverAlt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="closer" aria-labelledby="closer-heading">
    <div class="container closer__inner">
      <h2 id="closer-heading" class="closer__heading">
        See the thinking behind the work
      </h2>
      <p class="closer__body">
        The research, the trade-offs, and what actually shipped.
      </p>
      <a class="button" href="/work">Explore case studies <span aria-hidden="true">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Home sections sit on the flat Nightfall canvas (1b); the
     gradient lives in the hero, the glow in the closer. */

  /* ---- How I work — compact approach strip (1b) ---- */
  .approach {
    padding-block: var(--space-7);
  }

  .approach__heading {
    margin-block-start: var(--space-2);
    font-size: var(--text-xl);
  }

  .approach__grid {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .step {
    /* Deliberately the stronger border tier: the default divider is
       too faint against the flat dark canvas (De's call). */
    border-block-start: var(--border-thin) solid var(--color-border-control);
    padding-block-start: var(--space-4);
  }

  .step__number {
    display: block;
    font-family: var(--font-display);
    font-size: var(--text-md);
    color: var(--color-accent);
  }

  .step__title {
    margin-block-start: var(--space-2);
    font-weight: var(--weight-semibold);
  }

  .step__body {
    margin-block-start: var(--space-1);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-text-secondary);
  }

  /* ---- Work showcase ---- */
  .showcase {
    padding-block: var(--space-6) var(--space-7);
  }

  .showcase__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-5);
    margin-block-end: var(--space-6);
  }

  .showcase__heading {
    margin-block-start: var(--space-3);
    font-size: var(--text-2xl);
  }

  .showcase__all {
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    white-space: nowrap;
  }

  .showcase__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ---- Closing CTA — recessed band with magenta glow (1b) ---- */
  .closer {
    padding-block: var(--space-8) var(--space-9);
    text-align: center;
    background-color: var(--color-bg-recessed);
    background-image: var(--band-closer-glow);
    border-block-start: var(--border-thin) solid var(--color-border-divider);
  }

  .closer__heading {
    font-size: var(--text-2xl);
    max-width: 20ch;
    margin-inline: auto;
  }

  .closer__body {
    margin-block-start: var(--space-4);
    margin-inline: auto;
    color: var(--color-text-secondary);
    font-size: var(--text-md);
    max-width: 46ch;
  }

  .closer .button {
    margin-block-start: var(--space-6);
  }

  @media (max-width: 820px) {
    .approach__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .showcase__head {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 540px) {
    .approach__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
