---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WorkRow from '../components/WorkRow.astro';
import deannaIllus from '../assets/home/deanna-illus.png';

const projects = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

const approach = [
  {
    n: '01',
    title: 'Clarity & shared ownership',
    body: 'Inclusive by default. Bring in quieter voices early. Context is shared, ownership is clear.',
  },
  {
    n: '02',
    title: 'Evidence-led strategy',
    body: 'Research frames the problem and shapes measurable goals.',
  },
  {
    n: '03',
    title: 'Systems-level impact',
    body: 'Patterns, naming, and guidance that scales across.',
  },
  {
    n: '04',
    title: 'Glass Box',
    body: 'When software acts on your behalf, you should see what it is doing and be able to control it.',
  },
];

const values = [
  'Clarity & shared ownership',
  'Evidence-led strategy',
  'Systems-level impact',
  'AI with intention',
];
---

<BaseLayout theme="gradient">
  <Hero
    eyebrow="Product Design Leader · AI-UX"
    sub="Product designer working on agentic AI. I design the interaction model for systems that act on people's behalf, and build the tooling that gets it shipped."
    primaryLabel="Explore the work"
    primaryHref="/work"
    secondaryLabel="About me"
    secondaryHref="/about"
    image={deannaIllus}
    imageAlt="Illustration of Deanna Glaze"
  >
    I make complex systems clear, and <em>keep people in control of them</em>.
  </Hero>

  <section class="ai-band" aria-labelledby="ai-heading">
    <div class="container">
      <div class="ai-band__card">
      <div>
        <p class="eyebrow">AI-UX, with intention</p>
        <h2 id="ai-heading" class="ai-band__heading">
         Clarity first. Then agency.
        </h2>
        <p class="ai-band__body">
          I start with real use cases and the risks that come with them. I design for transparency and control, then watch how it behaves once it's live and keep refining.
        </p>
      </div>
      <ul class="ai-band__grid">
        {
          approach.map((step) => (
            <li class="step">
              <span class="step__number" aria-hidden="true">{step.n}</span>
              <p class="step__title">{step.title}</p>
              <p class="step__body">{step.body}</p>
            </li>
          ))
        }
      </ul>
      </div>
    </div>
  </section>

  <section class="showcase" aria-labelledby="work-heading">
    <div class="container">
      <div class="showcase__head">
        <div>
          <p class="eyebrow">Selected work</p>
          <h2 id="work-heading" class="showcase__heading">
            Case studies across AI, health, and enterprise platforms
          </h2>
        </div>
        <a class="showcase__all" href="/work">All work →</a>
      </div>
      <div class="showcase__list">
        {
          projects.map((project, i) => (
            <WorkRow
              href={`/work/${project.id}`}
              index={i + 1}
              client={project.data.client}
              category={project.data.category}
              title={project.data.shortTitle ?? project.data.title}
              tagline={project.data.tagline}
              chips={project.data.chips}
              highlightChip={project.data.highlightChip}
              featured={project.data.featured}
              cover={project.data.cover}
              coverAlt={project.data.coverAlt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="values" aria-labelledby="values-heading">
    <div class="container">
      <div class="values__card">
      <p class="eyebrow" id="values-heading">How I work</p>
      <p class="values__statement">
        Inclusive by default. Evidence-led. Systems that do the heavy lifting.
        And AI designed with intention.
      </p>
      <ul class="values__list">
        {values.map((value) => <li class="values__item">{value}</li>)}
      </ul>
      </div>
    </div>
  </section>

  <section class="closer" aria-labelledby="closer-heading">
    <div class="container closer__inner">
      <h2 id="closer-heading" class="closer__heading">
        See the thinking behind the work
      </h2>
      <p class="closer__body">
        The research, the trade-offs, and what actually shipped.
      </p>
      <a class="button" href="/work">Explore case studies <span aria-hidden="true">→</span></a>
    </div>
  </section>
</BaseLayout>

<style>
  /* All home sections sit transparently on the body gradient (3c). */

  /* ---- AI approach band (glass card) ---- */
  .ai-band {
    padding-block: var(--space-7);
  }

  .ai-band__card {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-8);
    align-items: start;
    background: var(--color-bg-raised);
    border: var(--border-thin) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-7);
  }

  .ai-band__heading {
    margin-block-start: var(--space-4);
    font-size: var(--text-xl);
  }

  .ai-band__body {
    margin-block-start: var(--space-5);
    color: var(--color-text-secondary);
    line-height: var(--leading-loose);
  }

  .ai-band__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .step {
    background: var(--color-bg-subtle);
    border: var(--border-thin) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .step__number {
    font-family: var(--font-display);
    font-size: var(--text-md);
    color: var(--color-text-muted);
  }

  .step__title {
    margin-block-start: var(--space-2);
    font-weight: var(--weight-semibold);
  }

  .step__body {
    margin-block-start: var(--space-1);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-text-secondary);
  }

  /* ---- Work showcase ---- */
  .showcase {
    padding-block: var(--space-6) var(--space-7);
  }

  .showcase__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-5);
    margin-block-end: var(--space-6);
  }

  .showcase__heading {
    margin-block-start: var(--space-3);
    font-size: var(--text-2xl);
  }

  .showcase__all {
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    text-decoration: none;
    white-space: nowrap;
  }

  .showcase__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ---- Values band (glass card) ---- */
  .values {
    padding-block: var(--space-2) var(--space-7);
  }

  .values__card {
    background: var(--color-bg-raised);
    border: var(--border-thin) solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-7);
  }

  .values__statement {
    margin-block-start: var(--space-5);
    font-family: var(--font-display);
    font-weight: var(--weight-medium);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    letter-spacing: -0.01em;
    max-width: 34ch;
  }

  .values__list {
    list-style: none;
    margin: var(--space-6) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .values__item {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
    border-inline-start: var(--border-thick) solid var(--color-border-control);
    padding-inline-start: var(--space-4);
  }

  /* ---- Closing CTA ---- */
  .closer {
    padding-block: var(--space-7) var(--space-9);
    text-align: center;
  }

  .closer__heading {
    font-size: var(--text-2xl);
    max-width: 20ch;
    margin-inline: auto;
  }

  .closer__body {
    margin-block-start: var(--space-4);
    margin-inline: auto;
    color: var(--color-text-secondary);
    font-size: var(--text-md);
    max-width: 46ch;
  }

  .closer .button {
    margin-block-start: var(--space-6);
  }

  @media (max-width: 820px) {
    .ai-band__card {
      grid-template-columns: 1fr;
      padding: var(--space-5);
    }

    .ai-band__grid {
      grid-template-columns: 1fr;
    }

    .showcase__head {
      flex-direction: column;
      align-items: flex-start;
    }

    .values__card {
      padding: var(--space-5);
    }
  }
</style>
