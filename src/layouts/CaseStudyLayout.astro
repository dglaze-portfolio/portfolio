---
import BaseLayout from './BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  entry: CollectionEntry<'work'>;
}

const { entry } = Astro.props;
const {
  title,
  tagline,
  description,
  client,
  category,
  role,
  roleActivities,
  skills,
  team,
  cover,
  coverAlt,
} = entry.data;

/* ---- Compute next project ---- */
const allProjects = await getCollection('work', ({ data }) => !data.draft);
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex((p) => p.id === entry.id);
const nextProject = sorted[(currentIndex + 1) % sorted.length];

/* Build the eyebrow label: "Client · Category" or just "Client" */
const eyebrowLabel = category ? `${client} · ${category}` : client;

/* Role activities: use dedicated field, fall back to skills */
const roleList = roleActivities.length > 0 ? roleActivities : skills;
---

<BaseLayout title={`${client}: ${title}`} description={tagline} theme="gradient">
  <article class="case-study">
    <!-- Back link -->
    <nav class="container case-back" aria-label="Back to work">
      <a href="/work" class="case-back__link">← All work</a>
    </nav>

    <!-- Hero -->
    <header class="container case-hero">
      <p class="eyebrow">{eyebrowLabel}</p>
      <h1 class="case-hero__title">{title}</h1>
      {(description || tagline) && (
        <p class="case-hero__description">{description || tagline}</p>
      )}

      <!-- Meta grid -->
      {(roleList.length > 0 || team.length > 0) && (
        <div class="case-meta-grid">
          {roleList.length > 0 && (
            <div class="meta-card">
              <p class="meta-card__label">My role</p>
              <ul class="meta-card__list">
                <li class="meta-card__list-item meta-card__list-item--lead">{role}</li>
                {roleList.map((item) => (
                  <li class="meta-card__list-item">{item}</li>
                ))}
              </ul>
            </div>
          )}
          {team.length > 0 && (
            <div class="meta-card">
              <p class="meta-card__label">The team</p>
              <ul class="meta-card__list">
                {team.map((member) => (
                  <li class="meta-card__list-item">{member}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      <!-- Fallback: simple role/skills display when no structured data -->
      {roleList.length === 0 && team.length === 0 && (
        <dl class="case-meta-simple">
          <div class="case-meta-simple__item">
            <dt>Role</dt>
            <dd>{role}</dd>
          </div>
          {skills.length > 0 && (
            <div class="case-meta-simple__item">
              <dt>Focus</dt>
              <dd>{skills.join(' · ')}</dd>
            </div>
          )}
        </dl>
      )}
    </header>

    <!-- Cover image (no lightbox — body images get one via
         rehype-image-lightbox) -->
    <section class="container case-cover">
      {cover ? (
        <Image
          class="case-cover__img"
          src={cover}
          alt={coverAlt ?? ''}
          widths={[768, 1120, 1680, 2240]}
          sizes="(max-width: 1200px) 100vw, 1120px"
          loading="eager"
        />
      ) : (
        <div class="case-cover__placeholder">
          <span class="case-cover__placeholder-name">{client}</span>
          <span class="case-cover__placeholder-label">Hero image · product screens</span>
        </div>
      )}
    </section>

    <!-- Body: centered reading column (structure per the Claude Design
         Case Study Template). Markdown images render in-column and get
         a zero-JS popover lightbox via rehype-image-lightbox. -->
    <div class="container container--narrow prose prose--article case-body">
      <slot />
    </div>
  </article>

  <!-- Next project -->
  {nextProject && nextProject.id !== entry.id && (
    <section class="container case-next">
      <a href={`/work/${nextProject.id}`} class="case-next__card">
        <div>
          <p class="case-next__label">Next project</p>
          <p class="case-next__title">
            {nextProject.data.client} — {nextProject.data.shortTitle || nextProject.data.title}
          </p>
        </div>
        <span class="case-next__arrow" aria-hidden="true">→</span>
      </a>
    </section>
  )}

  <CtaSection
    heading="Let's connect"
    body="Interested in collaborating or learning more about my work? Let's chat."
    buttonLabel="Get in touch →"
  />
</BaseLayout>

<style>
  /* ---- Back link ---- */
  .case-back {
    padding-block-start: var(--space-6);
  }

  .case-back__link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .case-back__link:hover {
    color: var(--color-text-secondary);
  }

  /* ---- Hero ---- */
  .case-hero {
    padding-block: var(--space-7) var(--space-2);
  }

  .case-hero .eyebrow {
    margin-block-end: var(--space-4);
  }

  .case-hero__title {
    font-size: var(--text-3xl);
    line-height: var(--leading-hero);
    letter-spacing: var(--tracking-tight);
    max-width: 20ch;
  }

  .case-hero__description {
    margin-block-start: var(--space-6);
    font-size: var(--text-md);
    line-height: var(--leading-normal);
    color: var(--color-text-secondary);
    max-width: 62ch;
  }

  /* ---- Meta grid (role + team cards) ---- */
  .case-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-block-start: 44px;
  }

  .meta-card {
    background: var(--glass-surface);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 26px 28px;
  }

  .meta-card__label {
    margin-block-end: 14px;
    font-size: 12px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .meta-card__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .meta-card__list-item {
    font-size: 15px;
    color: var(--color-text-secondary);
  }

  .meta-card__list-item--lead {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  /* ---- Simple meta fallback ---- */
  .case-meta-simple {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-block-start: var(--space-6);
  }

  .case-meta-simple__item dt {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .case-meta-simple__item dd {
    margin: var(--space-1) 0 0;
    font-size: var(--text-sm);
  }

  /* ---- Cover image ---- */
  .case-cover {
    margin-block-start: var(--space-8);
  }

  .case-cover__img {
    width: 100%;
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  .case-cover__placeholder {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    background: var(--color-bg-subtle);
    border: var(--border-thin) solid var(--card-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .case-cover__placeholder-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--color-text-secondary);
  }

  .case-cover__placeholder-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  /* ---- Body ---- */
  .case-body {
    padding-block: var(--space-9);
    /* reading column ~20% wider than --container-narrow (44rem),
       per De — applies to every case study */
    max-width: 53rem;
  }


  /* ---- Next project ---- */
  .case-next {
    padding-block-start: var(--space-9);
  }

  .case-next__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    background: var(--card-bg);
    border: var(--border-thin) solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-7);
    text-decoration: none;
    transition:
      background var(--duration-fast) var(--ease-out),
      translate var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .case-next__card:hover {
    translate: 0 -2px;
    box-shadow: var(--card-shadow-hover);
  }

  .case-next__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-block-end: var(--space-2);
  }

  .case-next__title {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--text-lg);
    color: var(--color-text);
  }

  .case-next__arrow {
    font-size: 1.75rem;
    color: var(--color-accent);
    flex: 0 0 auto;
  }

  /* ---- Responsive ---- */
  @media (max-width: 820px) {
    .case-meta-grid {
      grid-template-columns: 1fr;
    }

    .case-hero__title {
      max-width: none;
    }
  }
</style>
